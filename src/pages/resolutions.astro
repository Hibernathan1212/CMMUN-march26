---
import Layout from "../layouts/Layout.astro";
import Collapsable from "../components/collapsable.astro";
const siteTitle = "CMMUN March 2026";
const description = "Chiang Mai MUN Conference March 2026 ";
---

<Layout title={siteTitle} description={description}>
  <div
    class="relative flex min-h-screen flex-col items-center justify-center px-6 -mb-32"
  >
    <div
      class="pointer-events-none absolute top-1/2 left-1/2 h-150 w-150 -translate-x-1/2 -translate-y-1/2 rounded-full opacity-[0.03]"
      style="background: radial-gradient(circle, #22d3ee 0%, transparent 70%);"
    >
    </div>

    <div class="relative z-10 w-full">
      <header
        class="mb-16 opacity-0 animate-fade-in-up"
        style="animation-delay: 0s;"
      >
        <h1
          class="text-8xl tracking-tight text-text font-extralight text-center"
        >
          Resolutions
        </h1>
        <p
          class="text-lg tracking-tight font-extralight text-gray-300 text-center"
        >
          test
        </p>
      </header>
    </div>
  </div>

  <div class="border-t border-white/10 p-4 w-full pt-18">
    <Collapsable title="General Assembly 1"> test </Collapsable>
    <Collapsable title="General Assembly 2"> test </Collapsable>
    <Collapsable title="International Court of Justice"> test </Collapsable>
  </div>
</Layout>
