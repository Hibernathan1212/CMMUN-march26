---
import Layout from "../layouts/Layout.astro";
import SecProfile from "../components/SecProfiles.astro";
import GAProfile from "../components/GAProfiles.astro";
import CommitteeSection from "../components/CommitteeSection.astro";
import type { Committee } from "../components/CommitteeSection.astro";

import { Image } from "astro:assets";

const siteTitle = "CMMUN March 2026";
const description = "Chiang Mai MUN Conference March 2026 ";
import girl from "../assets/girl.avif";
import paris from "../assets/paris.avif";
---

<Layout title={siteTitle} description={description}>
  <div
    class="relative flex min-h-screen flex-col items-center justify-center px-6 -mb-24"
  >
    <div
      class="pointer-events-none absolute top-1/2 left-1/2 h-100 w-100 -translate-x-1/2 -translate-y-1/2 rounded-full opacity-[0.03]"
      style="background: radial-gradient(circle, #22d3ee 0%, transparent 70%);"
    >
    </div>

    <div class="relative z-10 w-full h-full max-w-6xl">
      <header
        class="mb-16 opacity-0 animate-fade-in-up grid grid-cols-1 md:grid-cols-2"
        style="animation-delay: 0s;"
      >
        <div>
          <h1 class="text-8xl tracking-tight text-text font-extralight -mt-8">
            CMMUN <br />
            March 2026
          </h1>
          <p class="text-lg tracking-tight font-extralight text-gray-300">
            Hosted by Prem International School
          </p>
        </div>
      </header>
    </div>
  </div>
  <div class="items-center justify-center border-t border-white/10 p-4 w-full">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-x-4 max-w-7xl mx-auto">
      <div class="mx-auto max-w-6xl pt-8 pl-4 pb-4">
        <h1 class="text-2xl font-light text-white pb-2">From Death (1963)</h1>
        <p class="text-base font-extralight text-gray-300 tracking-wide">
          I have never feared death<br />
          Even though<br />
          Its hands were more fragile<br />
          Than banality.<br />
          <br />
          I dread, however, to die<br />
          In a land where<br />
          The grave digger's wages<br />
          Exceed the price of human freedom.<br />
          <br />
          Looking for,<br />
          Discovering,<br />
          Choosing freely,<br />
          And transforming one's essence<br />
          Into a fortress.<br />
          <br />
          If the price of death is higher than all that,<br />
          I deny, in absolute terms,<br />
          To have ever feared death.<br />
          <br />
        </p>
        <p
          class="text-base text-right font-extralight text-gray-300 tracking-wide"
        >
          - Ahmad Shamlou &emsp;
        </p>
      </div>
      <div class="col-span-2 p-2 md:p-6 max-w-3xl mx-auto">
        <Image src={girl} alt="girl running" class="rounded-2xl w-full" />
        <p
          class="text-sm text-gray-300 pt-4 max-w-xl text-center md:text-right mx-auto md:mx-0 md:ml-auto md:mr-4"
        >
          A girl with a national flag runs in front of the local Palace of
          Culture destroyed by a Russian military strike, in the town of
          Derhachi, Kharkiv region, Derhachi, Ukraine.
        </p>
        <p
          class="text-sm font-light text-gray-400 text-center md:text-right mr-4"
        >
          June 17, 2023. REUTERS/Sofiia Gatilova
        </p>
      </div>
    </div>
    <div
      class="p-2 md:p-6 max-w-5xl mx-auto pt-8 border-t border-white/5 mt-16"
    >
      <Image src={paris} alt="paris" class="rounded-2xl mt-5" />
      <p class="text-sm text-gray-300 pt-4 max-w-xl text-center mx-auto">
        The Eiffel Tower is lit up in the national blue-and-yellow colours of
        Ukraine, to mark the first anniversary of Russia's invasion of Ukraine,
        in Paris, France.
      </p>
      <p class="text-sm font-light text-gray-400 text-center">
        February 23, 2023. REUTERS/Sarah Meyssonnier
      </p>
    </div>

    <div
      class="max-w-4xl mx-auto py-24 px-6 text-center border-t border-white/5 mt-16"
    >
      <p
        class="text-xl md:text-2xl font-extralight text-white leading-relaxed tracking-wide italic"
      >
        "Let us not seek the Republican answer or the Democratic answer, but the
        right answer. Let us not seek to fix the blame for the past. Let us
        accept our own responsibility for the future."
      </p>
      <p
        class="text-sm font-light text-gray-500 mt-6 tracking-[0.2em] uppercase"
      >
        — John F. Kennedy
      </p>
    </div>
  </div>
</Layout>
