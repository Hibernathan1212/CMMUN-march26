---
import Layout from "../layouts/Layout.astro";
import Collapsable from "../components/collapsable.astro";
const siteTitle = "CMMUN March 2026";
const description = "Chiang Mai MUN Conference March 2026 ";
---

<Layout title={siteTitle} description={description}>
  <div
    class="relative flex min-h-screen flex-col items-center justify-center px-6 -mb-32"
  >
    <div
      class="pointer-events-none absolute top-1/2 left-1/2 h-150 w-150 -translate-x-1/2 -translate-y-1/2 rounded-full opacity-[0.03]"
      style="background: radial-gradient(circle, #22d3ee 0%, transparent 70%);"
    >
    </div>

    <div class="relative z-10 w-full">
      <header
        class="mb-16 opacity-0 animate-fade-in-up"
        style="animation-delay: 0s;"
      >
        <h1
          class="text-8xl tracking-tight text-text font-extralight text-center"
        >
          Schedule
        </h1>
        <p
          class="text-lg tracking-tight font-extralight text-gray-300 text-center"
        >
          test
        </p>
      </header>
    </div>
  </div>
  <div class="border-t border-white/10 p-4 w-full pt-18">
    <Collapsable title="General Assembly 1"> Test </Collapsable>
    <Collapsable title="General Assembly 2"> Test </Collapsable>
    <div class="flex flex-wrap justify-center gap-6 py-8">
      <a
        href="https://docs.google.com/document/d/1uiEsPQXdzf2Zp0AZ0Z7WEFpd7ssQKkPgH8ZCpWXFylQ/edit?tab=t.0"
        class="group relative overflow-hidden animate-fade-in-up px-6 py-3 border border-white/10 rounded-xl hover:border-white/30 transition-colors duration-300"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="z-10 text-sm font-light tracking-wider flex items-center"
          >Full document

          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-3.5 w-3.5 ml-1"
            viewBox="0 0 20 20"
            fill="currentColor"
          >
            <path
              d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z"
            ></path>
            <path
              d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z"
            ></path>
          </svg>
        </span>
        <span
          class="absolute inset-0 bg-white/5 transform scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-500"
        ></span>
      </a>
    </div>
  </div>
</Layout>
