---
import { cn } from "../utils/cn";
import "../style/global.css";
import { ClientRouter } from "astro:transitions";
import PostHog from "../components/posthog.astro";

import logo from "../assets/logo.png";
import { Image } from "astro:assets";

interface Props {
  title: string;
  description: string;
  classNames?: {
    html?: string;
    body?: string;
    main?: string;
    footer?: string;
  };
  backToLink?:
    | false
    | {
        text: string;
        href: string;
      };
}

const defaultBackToLink: Props["backToLink"] = {
  text: "back",
  href: "/",
};

const {
  title,
  description,
  classNames,
  backToLink = defaultBackToLink,
} = Astro.props;
const isHomepage = Astro.url.pathname === "/";

const links = [
  {
    href: "https://docs.google.com/spreadsheets/d/1Og2zGMQ8FqeI1tAkJhY50IYHMqjZcv2x8Pw-7oWoNbo/edit?gid=1727275284#gid=1727275284",
    label: "Master Spreadsheet",
    external: true,
  },
  {
    href: "/resolutions",
    label: "Resolutions",
    external: false,
  },
  {
    href: "/schedule",
    label: "Schedule",
    external: false,
  },
  {
    href: "/map",
    label: "Map",
    external: false,
  },
  {
    href: "/Rules of Procedure - March CMMUN 2026.pdf",
    label: "RoP",
    external: true,
  },
];
---

<html
  lang="en"
  class={cn("h-full bg-void", classNames?.html)}
  style="view-transition-name:root"
>
  <head>
    <ClientRouter />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="color-scheme" content="dark" />
    <link rel="icon" href="/favicon.svg" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <meta name="theme-color" content="#050505" />
    <PostHog />
  </head>
  <body
    class={cn(
      "min-h-full bg-void font-sans text-text selection:bg-accent/20",
      classNames?.body,
    )}
  >
    <main class={cn("flex min-h-screen flex-col text-text", classNames?.main)}>
      <header
        class="fixed top-0 left-0 w-full z-50 flex justify-center transition:persist"
        style="animation-delay: 0s;"
      >
        <!-- Blur Overlay for Background -->
        <div
          id="menu-overlay"
          class="fixed inset-0 bg-black/40 backdrop-blur-md opacity-0 pointer-events-none transition-opacity duration-500 md:hidden"
        >
        </div>

        <div
          id="header-container"
          class="flex items-center justify-between w-full max-w-4xl p-2 px-6 mt-6 bg-[#222222]/90 backdrop-blur-md rounded-full shadow-2xl border border-white/10 mx-4 relative z-50 transition-all duration-500"
        >
          <a
            href="/"
            class="text-2xl font-serif px-2 font-extralight transition-colors hover:text-white text-gray-200 z-50"
          >
            CMMUN
          </a>

          <button
            id="menu-toggle"
            class="md:hidden p-2 text-gray-300 hover:text-white focus:outline-none z-50"
            aria-label="Toggle Menu"
          >
            <svg
              viewBox="0 0 24 24"
              class="h-6 w-6"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                id="line-top"
                d="M4 7h16"
                class="transition-all duration-300 origin-[50%_50%]"></path>
              <path
                id="line-bottom"
                d="M4 17h16"
                class="transition-all duration-300 origin-[50%_50%]"></path>
            </svg>
          </button>

          <nav
            id="nav-menu"
            class="hidden md:flex items-center gap-6 text-sm font-medium text-gray-300 absolute md:static top-[70px] left-0 w-full md:w-auto bg-[#222222]/95 md:bg-transparent p-8 md:p-0 rounded-[2rem] md:rounded-none border border-white/10 md:border-none shadow-2xl md:shadow-none transition-all duration-500 opacity-0 md:opacity-100 scale-95 md:scale-100 pointer-events-none md:pointer-events-auto"
          >
            <div
              class="flex flex-col md:flex-row items-start md:items-center gap-4 md:gap-6 w-full"
            >
              {
                links.map((link, i) => (
                  <a
                    href={link.href}
                    target={link.external ? "_blank" : undefined}
                    rel={link.external ? "noopener noreferrer" : undefined}
                    class="flex items-center justify-between py-2 hover:text-white transition-colors font-extralight text-lg w-full md:w-auto"
                  >
                    {link.label}
                    {link.external && (
                      <svg
                        xmlns="http://www.w3.org"
                        class="h-3.5 w-3.5 ml-1"
                        viewBox="0 0 20 20"
                        fill="currentColor"
                      >
                        <path d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z" />
                        <path d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z" />
                      </svg>
                    )}
                  </a>
                ))
              }
            </div>
          </nav>
        </div>
      </header>
      <slot />
      <footer
        class={cn(
          "[--space:--spacing(6)] sm:[--space:--spacing(10)]",
          "border-t border-white/10 pt-(--space) pb-safe-offset-(--space)",
          classNames?.footer,
        )}
      >
        <div class="container mx-auto px-4 mb-6">
          <div
            class="w-full items-center justify-center gap-x-6 text-sm tracking-wider"
          >
            <div
              class="justify-start items-center gap-x-2 md:gap-x-6 flex pb-6 md:pb-12"
            >
              <!-- <p>logo</p> -->
              <Image
                src={logo}
                alt="logo"
                fit="fill"
                class="object-cover w-36"
              />
              <h2
                class="font-sans text-3xl md:text-5xl tracking-tight font-light"
              >
                Chiang Mai <br />
                Model United Nations
              </h2>
            </div>
            <div class="border-white/60 border-t"></div>

            <div
              class="grid grid-cols-2 justify-center items-center gap-x-6 pt-6 pb-4"
            >
              <div class="flex flex-col gap-0">
                {
                  links.map((link, i) => (
                    <a
                      href={link.href}
                      target={link.external ? "_blank" : undefined}
                      rel={link.external ? "noopener noreferrer" : undefined}
                      class="group relative items-center justify-between py-2 opacity-0 animate-fade-in-up"
                      style={`animation-delay: ${(i + 1) * 0.05}s;`}
                    >
                      <span class="relative flex items-center w-fit text-white/80 font-extralight text-md transition-colors duration-200 group-hover:text-text">
                        {link.label}
                        {link.external ? (
                          <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="h-3.5 w-3.5 ml-1"
                            viewBox="0 0 20 20"
                            fill="currentColor"
                          >
                            <path d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z" />
                            <path d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z" />
                          </svg>
                        ) : (
                          <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="h-3.5 w-3.5"
                            viewBox="0 0 20 20"
                            fill="currentColor"
                          >
                            <path
                              fill-rule="evenodd"
                              d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                              clip-rule="evenodd"
                            />
                          </svg>
                        )}

                        <span class="absolute -bottom-1 left-0 h-px w-0 bg-white/40 transition-all duration-300 ease-out group-hover:w-full" />
                      </span>
                    </a>
                  ))
                }
              </div>
              <div class="flex justify-end items-end">
                <span
                  class="text-right text-white/80 font-extralight leading-relaxed text-md group-hover:text-text"
                >
                  <br />
                  <br />
                  <a
                    href={`mailto:sophiamu@ptis.ac.th`}
                    class="w-max group relative"
                  >
                    sophiamu@ptis.ac
                    <span
                      class="absolute -bottom-1 left-0 h-px w-0 bg-white/40 transition-all duration-300 ease-out group-hover:w-full"
                    ></span>
                  </a>
                  <br />
                  <a
                    href={`mailto:moepwintt@ptis.ac.th`}
                    class="w-max group relative"
                  >
                    moepwintt@ptis.ac.th
                    <span
                      class="absolute -bottom-1 left-0 h-px w-0 bg-white/40 transition-all duration-300 ease-out group-hover:w-full"
                    ></span>
                  </a>
                  <br />CMMUN MARCH 2026 <br />
                  Prem Tinsulonda International School <br />
                  <br />
                  <p
                    class="text-left text-white/50 font-extralight text-xs md:text-sm"
                  >
                    Copyright &copy; 2026 CMMUN. All Rights Reserved.
                  </p>
                </span>
              </div>
            </div>
          </div>
        </div>
      </footer>
    </main>
  </body>
</html>

<style>
  /* Mobile Open State */
  :global(body.menu-open) #nav-menu {
    display: flex;
    opacity: 1;
    scale: 1;
    pointer-events: auto;
    transform: translateY(10px);
  }

  :global(body.menu-open) #menu-overlay {
    opacity: 1;
    pointer-events: auto;
  }

  :global(body.menu-open) #line-top {
    transform: translateY(4.25px) rotate(45deg);
  }
  :global(body.menu-open) #line-bottom {
    transform: translateY(-4.25px) rotate(-45deg);
  }
</style>

<script is:inline>
  const setupToggle = () => {
    const btn = document.getElementById("menu-toggle");
    const overlay = document.getElementById("menu-overlay");

    const toggleMenu = () => {
      document.body.classList.toggle("menu-open");
      const isOpen = document.body.classList.contains("menu-open");
      document.body.style.overflow = isOpen ? "hidden" : "";
    };

    btn?.addEventListener("click", toggleMenu);
    overlay?.addEventListener("click", toggleMenu);

    // Close menu when a link is clicked
    document.querySelectorAll("#nav-menu a").forEach((link) => {
      link.addEventListener("click", () => {
        document.body.classList.remove("menu-open");
        document.body.style.overflow = "";
      });
    });
  };

  setupToggle();
  document.addEventListener("astro:after-swap", setupToggle);
</script>
