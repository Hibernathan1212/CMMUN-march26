---
import { cn } from "../utils/cn";
import "../style/global.css";
import { ClientRouter } from "astro:transitions";
import PostHog from "../components/posthog.astro";

interface Props {
  title: string;
  description: string;
  classNames?: {
    html?: string;
    body?: string;
    main?: string;
    footer?: string;
  };
  backToLink?:
    | false
    | {
        text: string;
        href: string;
      };
}

const defaultBackToLink: Props["backToLink"] = {
  text: "back",
  href: "/",
};

const {
  title,
  description,
  classNames,
  backToLink = defaultBackToLink,
} = Astro.props;
const isHomepage = Astro.url.pathname === "/";

const links = [
  {
    href: "https://docs.google.com/spreadsheets/d/1Og2zGMQ8FqeI1tAkJhY50IYHMqjZcv2x8Pw-7oWoNbo/edit?gid=1727275284#gid=1727275284",
    label: "Master Spreadsheet",
    external: true,
  },
  {
    href: "/resolutions",
    label: "Resolutions",
    external: false,
  },
  {
    href: "/schedule",
    label: "Schedule",
    external: false,
  },
  {
    href: "/map",
    label: "Map",
    external: false,
  },
  {
    href: "/Rules of Procedure - March CMMUN 2026.pdf",
    label: "RoP",
    external: false,
  },
];
---

<html
  lang="en"
  class={cn("h-full bg-void", classNames?.html)}
  style="view-transition-name:root"
>
  <head>
    <ClientRouter />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="color-scheme" content="dark" />
    <link rel="icon" href="/favicon.svg" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <meta name="theme-color" content="#050505" />
    <PostHog />
  </head>
  <body
    class={cn(
      "min-h-full bg-void font-sans text-text selection:bg-accent/20",
      classNames?.body,
    )}
  >
    <main class={cn("flex min-h-screen flex-col text-text", classNames?.main)}>
      <header
        class="fixed top-0 left-0 w-full z-50 flex justify-center transition:persist"
        style="animation-delay: 0s;"
      >
        <div
          class="flex items-center justify-between w-full max-w-4xl p-2 px-6 mt-6 bg-[#222222]/90 backdrop-blur-md rounded-full shadow-2xl border border-white/10"
        >
          <a
            href="/"
            class="text-2xl font-serif px-2 font-extralight transition-colors hover:text-white text-gray-200"
          >
            CMMUN
          </a>

          <nav
            class="md:flex items-center gap-6 text-sm font-medium text-gray-300"
          >
            {
              links.map((link, i) => (
                <a
                  href={link.href}
                  target={link.external ? "_blank" : undefined}
                  rel={link.external ? "noopener noreferrer" : undefined}
                  class="flex items-center justify-between py-2 hover:text-white transition-colors font-extralight text-lg"
                >
                  {link.label}
                  {link.external && (
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="h-3.5 w-3.5 ml-1"
                      viewBox="0 0 20 20"
                      fill="currentColor"
                    >
                      <path d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z" />
                      <path d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z" />
                    </svg>
                  )}
                </a>
              ))
            }
          </nav>
        </div>
      </header>
      <slot />
      <footer
        class={cn(
          "[--space:--spacing(6)] sm:[--space:--spacing(10)]",
          "border-t border-white/10 pt-(--space) pb-safe-offset-(--space)",
          classNames?.footer,
        )}
      >
        <div class="container mx-auto px-4 mb-10">
          <div
            class="w-full items-center justify-center gap-x-6 text-sm tracking-wider"
          >
            <div class="justify-start items-center gap-x-6 flex pt-6 pb-12">
              <p>logo</p>
              <h2 class="font-sans text-5xl tracking-tight font-light">
                Chiang Mai <br />
                Model United Nations
              </h2>
            </div>
            <div class="border-white/60 border-t"></div>

            <div
              class="grid grid-cols-2 justify-center items-center gap-x-6 pt-6 pb-4"
            >
              <div class="flex flex-col gap-0">
                {
                  links.map((link, i) => (
                    <a
                      href={link.href}
                      target={link.external ? "_blank" : undefined}
                      rel={link.external ? "noopener noreferrer" : undefined}
                      class="group relative items-center justify-between py-2 opacity-0 animate-fade-in-up"
                      style={`animation-delay: ${(i + 1) * 0.05}s;`}
                    >
                      <span class="relative flex items-center w-fit text-white/80 font-extralight text-md transition-colors duration-200 group-hover:text-text">
                        {link.label}
                        {link.external ? (
                          <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="h-3.5 w-3.5 ml-1"
                            viewBox="0 0 20 20"
                            fill="currentColor"
                          >
                            <path d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z" />
                            <path d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z" />
                          </svg>
                        ) : (
                          <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="h-3.5 w-3.5"
                            viewBox="0 0 20 20"
                            fill="currentColor"
                          >
                            <path
                              fill-rule="evenodd"
                              d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                              clip-rule="evenodd"
                            />
                          </svg>
                        )}

                        <span class="absolute -bottom-1 left-0 h-px w-0 bg-white/40 transition-all duration-300 ease-out group-hover:w-full" />
                      </span>
                    </a>
                  ))
                }
              </div>
              <div class="flex justify-end items-end">
                <span
                  class="text-right text-white/80 font-extralight leading-relaxed text-md group-hover:text-text"
                >
                  <br />
                  <br />
                  Contact information: <br />
                  @ptis.ac <br />
                  CMMUN MARCH 2026 <br />
                  Prem Tinsulonda International School <br />
                  <br />
                  <p class="text-left text-white/60 font-extralight text-sm">
                    Copyright &copy; 2026 asdlfkj. All Rights Reserved.
                  </p>
                </span>
              </div>
            </div>
          </div>
        </div>
      </footer>
    </main>
  </body>
</html>
