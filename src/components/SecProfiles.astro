---
import { Image } from "astro:assets";

interface Props {
  name: string;
  position: string;
  email: string;
  imageSrc: ImageMetadata;
  imageRight?: boolean;
}

const { name, position, email, imageSrc, imageRight = false } = Astro.props;
---

<div class="grid grid-cols-3 justify-center items-center py-4">
  <div
    class:list={[
      "col-span-1 rounded-4xl overflow-hidden shadow-xl shadow-black/40",
      { "order-last": imageRight },
    ]}
  >
    <Image src={imageSrc} alt={name} width={imageSrc.width} />
  </div>

  <div
    class:list={[
      "col-span-2 p-4",
      { "text-right flex flex-col items-end": imageRight },
    ]}
  >
    <h3
      class="text-3xl md:text-6xl font-serif tracking-wide w-max mb-2 px-0 md:px-4"
    >
      {name}
      <div class="border-t-3 border-mist-500/80 mt-1"></div>
    </h3>
    <p class="text-xl md:text-3xl px-0 md:px-4">{position}</p>
    <a
      href={`mailto:${email}`}
      class="text-md md:text-2xl font-sans font-extralight text-white/60 w-max group relative px-0 md:px-4"
    >
      {email}
      <span
        class="absolute -bottom-1 left-0 h-px w-0 bg-white/40 transition-all duration-300 ease-out group-hover:w-full"
      ></span>
    </a>
  </div>
</div>
